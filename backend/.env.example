# MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pairpocket

# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:3000

# Secret used to sign the app JWT and the OAuth session.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an "Authorized redirect URI" registered in Google Cloud Console.
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Where the backend redirects the user after a successful login.
FRONTEND_URL=http://localhost:3000

# --- Email (Resend — recommended, one API key for the whole app) ---
# 1. https://resend.com 가입 (무료)
# 2. API Keys → Create → 복사
# 3. 아래에 붙여넣기 → 백엔드 재시작
# 사용자는 별도 설정 없이 Google 로그인 이메일로 알림을 받습니다.
RESEND_API_KEY=
EMAIL_FROM=PairPocket <onboarding@resend.dev>

# --- Cron (daily subscription reminder emails) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# GitHub Actions calls POST /api/internal/cron/subscription-reminders with header X-Cron-Secret
CRON_SECRET=

# --- Legacy SMTP (optional, only if you prefer Gmail SMTP) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
